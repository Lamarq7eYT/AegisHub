{
  "name": "aegishub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "aegishub": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint src --ext .ts",
    "scan": "pnpm build && node dist/index.js scan",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "execa": "^9.5.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "vitest": "^4.1.5"
  }
}
